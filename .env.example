# API는 /api/v1/chat, /health처럼 루트 기준 경로를 사용합니다.
# 같은 출처를 사용하면 값을 비워 두세요.
# Vercel에서 Render를 직접 호출할 때는 https://your-service.onrender.com 형식만 사용합니다.
VITE_API_BASE_URL=

# Cloudflare Worker가 동일 출처 /api 요청을 전달할 백엔드 주소입니다.
# 로컬 개발은 값이 없을 때 http://localhost:3000을 사용합니다.
BACKEND_ORIGIN=http://localhost:3000

# API 키, DB 비밀번호, Claude 키 등 비밀값은 VITE_ 변수에 넣지 않습니다.
# 로컬 백엔드의 비밀값은 서버 전용 .env에, 운영 환경은 AWS Secrets Manager에 저장합니다.
